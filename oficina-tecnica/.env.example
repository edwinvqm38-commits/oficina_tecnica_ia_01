# Oficina Tecnica IA - example environment
# Copy this file to .env.local and fill values locally.
# Never commit .env.local or real API keys.

# Public app configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_WORKSPACE_SYNC=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=
TOGETHER_API_KEY=
HUGGINGFACE_API_KEY=

# Google Drive OAuth
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=

# Gmail OAuth / sender
GOOGLE_GMAIL_OAUTH_CLIENT_ID=
GOOGLE_GMAIL_OAUTH_CLIENT_SECRET=
GOOGLE_GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback
GOOGLE_GMAIL_OAUTH_REFRESH_TOKEN=
GOOGLE_GMAIL_SENDER_EMAIL=
GOOGLE_WORKSPACE_SENDER_EMAIL=
